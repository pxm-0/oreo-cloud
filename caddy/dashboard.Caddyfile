# Generated private Oreo Cloud dashboard route.
# Review, back up /etc/caddy/Caddyfile, validate, then reload manually.
http://oreochiserver:8088, http://100.75.210.83:8088 {
    bind 100.75.210.83
    root * /srv/oreo-cloud/control-plane/dashboard/public
    handle /api/* {
        reverse_proxy 127.0.0.1:8099
    }
    file_server
}
