# Replace 100.x.y.z with: tailscale ip -4 | head -n 1
# This block should be appended only after backing up and validating Caddyfile.

http://oreochiserver:8088, http://100.x.y.z:8088 {
    bind 100.x.y.z
    root * /srv/oreo-cloud/control-plane/dashboard/public

    handle /api/* {
        reverse_proxy 127.0.0.1:8099
    }

    file_server
}
