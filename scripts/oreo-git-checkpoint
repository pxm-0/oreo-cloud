#!/usr/bin/env python3
from __future__ import annotations

import argparse

from oreo_common import fail, run_git


def main() -> int:
    parser = argparse.ArgumentParser(description="Create an explicit Oreo Cloud Git checkpoint.")
    parser.add_argument("message", nargs="?", default="Oreo Cloud checkpoint")
    args = parser.parse_args()

    status = run_git(["status", "--short"])
    if status.returncode != 0:
        fail(status.stderr.strip() or "git status failed")
    if not status.stdout.strip():
        print("No changes to checkpoint.")
        return 0
    add = run_git(["add", "-A"])
    if add.returncode != 0:
        fail(add.stderr.strip() or "git add failed")
    commit = run_git(["commit", "-m", args.message])
    if commit.returncode != 0:
        fail(commit.stderr.strip() or "git commit failed")
    print(commit.stdout.strip())
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
