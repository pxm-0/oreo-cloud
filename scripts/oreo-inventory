#!/usr/bin/env python3
from __future__ import annotations

import shutil
import subprocess

from oreo_common import load_json, root, workloads


def cmd_version(command: str, args: list[str]) -> str:
    if not shutil.which(command):
        return "not-found"
    result = subprocess.run([command, *args], text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False)
    return result.stdout.splitlines()[0] if result.stdout else "unknown"


def main() -> int:
    repo = root()
    print(f"root: {repo}")
    print(f"workloads: {len(workloads())}")
    print(f"docker: {cmd_version('docker', ['--version'])}")
    print(f"git: {cmd_version('git', ['--version'])}")
    print(f"tailscale: {cmd_version('tailscale', ['version'])}")
    print(f"cloudflare-enabled: {load_json('exposure.json')['providers']['cloudflare']['enabled']}")
    print(f"funnel-allowed-in-p0: {load_json('policy.json')['rules'].get('allowFunnelInP0', False)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
