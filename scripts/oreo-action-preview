#!/usr/bin/env python3
from __future__ import annotations

import argparse

from oreo_actions import backup_preview, logs_preview, restart_preview
from oreo_common import print_json


def main() -> int:
    parser = argparse.ArgumentParser(description="Preview a safe Oreo Cloud workload action.")
    parser.add_argument("action", choices=["logs", "restart", "backup"])
    parser.add_argument("workload_id")
    parser.add_argument("--max-lines", type=int, default=100)
    args = parser.parse_args()

    if args.action == "logs":
        payload = logs_preview(args.workload_id, max_lines=args.max_lines)
    elif args.action == "restart":
        payload = restart_preview(args.workload_id)
    else:
        payload = backup_preview(args.workload_id)
    print_json(payload)
    return 0 if payload.get("allowed", False) or payload.get("ok", False) else 2


if __name__ == "__main__":
    raise SystemExit(main())
