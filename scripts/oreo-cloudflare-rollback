#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import subprocess

from oreo_common import audit, regenerate_dashboard
from oreo_cloudflare_activation import activation_plan, lower_effective


def reload_cloudflared() -> dict[str, object]:
    result = subprocess.run(
        ["systemctl", "reload-or-restart", "cloudflared"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    return {"ok": result.returncode == 0, "stdout": result.stdout.strip(), "stderr": result.stderr.strip()}


def main() -> int:
    parser = argparse.ArgumentParser(description="Rollback a P2 Cloudflare protected activation.")
    parser.add_argument("workload_id", nargs="?", default="hello-nginx")
    parser.add_argument("--apply", action="store_true", help="Lower effective access and reload cloudflared.")
    parser.add_argument("--confirm-workload", default="")
    parser.add_argument("--no-reload", action="store_true")
    args = parser.parse_args()

    plan = activation_plan(args.workload_id)
    payload = {
        "ok": True,
        "workloadId": args.workload_id,
        "hostname": plan.get("hostname", ""),
        "wouldLowerEffectiveTo": "local",
        "wouldPreserveEvidence": True,
        "apply": bool(args.apply),
    }
    if not args.apply:
        print(json.dumps(payload, indent=2, sort_keys=True))
        audit("cloudflare.rollback.preview", args.workload_id, "ok", hostname=payload["hostname"])
        return 0
    if args.confirm_workload != args.workload_id:
        payload.update({"ok": False, "reason": "workload confirmation did not match"})
        print(json.dumps(payload, indent=2, sort_keys=True))
        audit("cloudflare.rollback", args.workload_id, "blocked", reason=payload["reason"])
        return 2

    lower_effective(args.workload_id)
    regenerate_dashboard(quiet=True)
    reload_result = {"ok": True, "skipped": True} if args.no_reload else reload_cloudflared()
    payload["reload"] = reload_result
    audit("cloudflare.rollback", args.workload_id, "ok" if reload_result["ok"] else "warning", reload=reload_result)
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0 if reload_result["ok"] else 2


if __name__ == "__main__":
    raise SystemExit(main())
