#!/usr/bin/env python3
from __future__ import annotations

import argparse

from oreo_actions import backup_apply, restart_apply
from oreo_common import print_json


def main() -> int:
    parser = argparse.ArgumentParser(description="Apply a safe Oreo Cloud workload action.")
    parser.add_argument("action", choices=["restart", "backup"])
    parser.add_argument("workload_id")
    parser.add_argument("--confirm", default="", help="Exact workload ID required for apply.")
    args = parser.parse_args()

    if args.action == "restart":
        payload = restart_apply(args.workload_id, confirmation=args.confirm)
    else:
        payload = backup_apply(args.workload_id, confirmation=args.confirm)
    print_json(payload)
    return 0 if payload.get("ok", False) and payload.get("allowed", False) else 2


if __name__ == "__main__":
    raise SystemExit(main())
