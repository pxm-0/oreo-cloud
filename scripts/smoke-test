import json
import os
import shutil
import subprocess
import tarfile
import tempfile
import time
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any

from oreo_actions import sanitize_log_text


MIGRATION_STATUSES = {"planned", "needs-discovery", "migrated", "blocked", "deprecated"}
BACKUP_STATUSES = {"planned", "configured", "needs-discovery", "disabled", "blocked", "ok"}
SAFE_CLOUDFLARE_PRIVACY = {"unclassified", "personal", "internal"}
OPERATION_SCRIPTS = [
    "oreo-logs",
    "oreo-restart-preview",
    "oreo-restart",
    "oreo-backup-plan",
    "oreo-backup-run",
    "oreo-restore-plan",
    "oreo-events",
    "oreo-action-preview",
    "oreo-action-apply",
    "oreo-access-reconcile",
    "oreo-cloudflare-activate-preview",
    "oreo-cloudflare-activate",
    "oreo-cloudflare-rollback",
]
OPERATOR_LINKS = {
    "oreo-logs": "oreo-logs",
    "oreo-restart-preview": "oreo-restart-preview",
    "oreo-restart": "oreo-restart",
    "oreo-backup-plan": "oreo-backup-plan",
    "oreo-backup-run": "oreo-backup-run",
    "oreo-restore-plan": "oreo-restore-plan",
    "oreo-events": "oreo-events",
    "oreo-cloud-smoke-test": "smoke-test",
    "oreo-access-preview": "oreo-access-preview",
    "oreo-access-apply": "oreo-access-apply",
    "oreo-access-reconcile": "oreo-access-reconcile",
    "oreo-cloudflare-plan": "oreo-cloudflare-plan",
    "oreo-cloudflare-activate-preview": "oreo-cloudflare-activate-preview",
    "oreo-cloudflare-activate": "oreo-cloudflare-activate",
    "oreo-cloudflare-rollback": "oreo-cloudflare-rollback",
}


def run(command: list[str], cwd: Path, env: dict[str, str] | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, cwd=cwd, env=env, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False)


def load_json_file(path: Path) -> Any:
    return json.loads(path.read_text())


def tracked_files(repo: Path) -> list[str]:
    result = run(["git", "ls-files"], repo)
    if result.returncode != 0:
        return []
    return result.stdout.splitlines()


def workload_map(repo: Path) -> dict[str, dict[str, Any]]:
    data = load_json_file(repo / "config" / "workloads.json")
    return {str(item.get("id")): item for item in data.get("workloads", [])}


def load_manifest(repo: Path, workload_id: str) -> dict[str, Any]:
    path = repo / "workloads" / workload_id / "manifest.json"
    if not path.exists():
        return {}
    data = load_json_file(path)
    return data if isinstance(data, dict) else {}


def privacy_for(repo: Path, workload_id: str) -> str:
    privacy = load_json_file(repo / "config" / "privacy.json")
    item = privacy.get("workloads", {}).get(workload_id, {})
    return str(item.get("privacy", privacy.get("defaultPrivacy", "")))


class Smoke:
    def __init__(self) -> None:
        self.failures: list[str] = []
        self.warnings: list[str] = []

    def pass_(self, message: str) -> None:
        print(f"PASS {message}")

    def fail(self, message: str) -> None:
        print(f"FAIL {message}")
        self.failures.append(message)

    def warn(self, message: str) -> None:
        print(f"WARN {message}")
        self.warnings.append(message)

    def check(self, condition: bool, message: str) -> None:
        if condition:
            self.pass_(message)
        else:
            self.fail(message)


def check_git(repo: Path, smoke: Smoke) -> None:
    result = run(["git", "rev-parse", "--is-inside-work-tree"], repo)
    smoke.check(result.returncode == 0 and result.stdout.strip() == "true", "Git repo exists")
    tag = run(["git", "rev-parse", "-q", "--verify", "refs/tags/p1-complete"], repo)
    smoke.check(tag.returncode == 0, "p1-complete tag exists")


def check_json(repo: Path, smoke: Smoke) -> None:
    ok = True
    config_paths = [path for path in sorted((repo / "config").glob("*.json")) if not path.name.startswith("._")]
    for path in config_paths:
        try:
            json.loads(path.read_text())
        except Exception:
            ok = False
            smoke.fail(f"{path.relative_to(repo)} valid JSON")
        else:
            smoke.pass_(f"{path.relative_to(repo)} valid JSON")
    if not config_paths:
        smoke.fail("JSON configs exist")
    elif ok:
        smoke.pass_("JSON configs valid")


def check_dashboard(repo: Path, smoke: Smoke) -> None:
    for name in ["index.html", "style.css", "app.js"]:
        smoke.check((repo / "control-plane" / "dashboard" / "public" / name).exists(), f"dashboard {name} generated")


def check_dashboard_runtime_cleanliness(repo: Path, smoke: Smoke) -> None:
    assets = [repo / "control-plane" / "dashboard" / "public" / name for name in ["index.html", "style.css", "app.js"]]
    before = {path: path.read_bytes() for path in assets if path.exists()}
    state_result = run([str(repo / "scripts" / "oreo-dashboard-state")], repo)
    if state_result.returncode != 0:
        smoke.fail("dashboard runtime state generated")
        return
    generator_result = run(["python3", str(repo / "control-plane" / "dashboard" / "generate_dashboard.py")], repo)
    if generator_result.returncode != 0:
        smoke.fail("dashboard generation clean")
        return
    after = {path: path.read_bytes() for path in assets if path.exists()}
    smoke.check(before == after, "dashboard generation clean")
    ignored = run(["git", "check-ignore", "-q", "runtime/dashboard-state.json"], repo)
    smoke.check(ignored.returncode == 0, "runtime dashboard state ignored")


def request_json(url: str, *, method: str = "GET", token: str = "", payload: dict[str, Any] | None = None) -> tuple[int, dict[str, Any], str]:
    body = json.dumps(payload or {}).encode()
    request = urllib.request.Request(url, data=body if method != "GET" else None, method=method)
    if method != "GET":
        request.add_header("Content-Type", "application/json")
    if token:
        request.add_header("Authorization", f"Bearer {token}")
    try:
        with urllib.request.urlopen(request, timeout=4) as response:
            text = response.read().decode()
            return response.status, json.loads(text), text
    except urllib.error.HTTPError as exc:
        text = exc.read().decode()
        try:
            data = json.loads(text)
        except json.JSONDecodeError:
            data = {}
        return exc.code, data, text


def check_action_api_boundaries(repo: Path, smoke: Smoke) -> None:
    token = "smoke-action-token"
    with tempfile.TemporaryDirectory() as tempdir:
        token_file = Path(tempdir) / "control-token"
        token_file.write_text(token)
        env = os.environ.copy()
        env["OREO_CLOUD_API_PORT"] = "18104"
        env["OREO_CLOUD_TOKEN_FILE"] = str(token_file)
        process = subprocess.Popen(
            ["python3", str(repo / "control-plane" / "api" / "server.py")],
            cwd=repo,
            env=env,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        try:
            deadline = time.time() + 5
            ready = False
            while time.time() < deadline:
                try:
                    status, _, _ = request_json("http://127.0.0.1:18104/api/actions")
                except OSError:
                    time.sleep(0.2)
                    continue
                ready = status == 200
                if ready:
                    break
            if not ready:
                smoke.fail("control API action endpoints available")
                return
            unauth_status, _, _ = request_json("http://127.0.0.1:18104/api/workloads/hello-nginx/restart/preview", method="POST")
            smoke.check(unauth_status == 401, "control API action endpoints require auth")
            status, payload, text = request_json(
                "http://127.0.0.1:18104/api/workloads/hello-nginx/restart/preview",
                method="POST",
                token=token,
            )
            smoke.check(status == 200 and payload.get("operation") == "restart-preview", "restart preview non-mutating")
            smoke.check("docker compose" not in text and "compose -f" not in text, "dashboard action responses omit raw shell commands")
            blocked_status, blocked_payload, _ = request_json(
                "http://127.0.0.1:18104/api/workloads/hello-nginx/backup/apply",
                method="POST",
                token=token,
                payload={"confirmation": ""},
            )
            manifest_status, manifest_payload, _ = request_json(
                "http://127.0.0.1:18104/api/workloads/dozzle/backup/apply",
                method="POST",
                token=token,
                payload={"confirmation": "dozzle"},
            )
            smoke.check(
                blocked_status == 403
                and blocked_payload.get("ok") is False
                and manifest_status == 403
                and manifest_payload.get("ok") is False,
                "backup execution gated by manifest",
            )
        finally:
            process.terminate()
            try:
                process.wait(timeout=4)
            except subprocess.TimeoutExpired:
                process.kill()
                process.wait(timeout=4)


def check_api_bind(repo: Path, smoke: Smoke, offline: bool) -> None:
    if offline:
        smoke.warn("API bind check skipped in offline mode")
        return
    if not shutil.which("ss"):
        smoke.warn("ss unavailable; API bind check skipped")
        return
    result = run(["ss", "-tulpen"], repo)
    lines = [line for line in result.stdout.splitlines() if ":8099" in line]
    if not lines:
        smoke.fail("control API listener found on :8099")
        return
    public = [line for line in lines if "127.0.0.1:8099" not in line]
    smoke.check(not public, "control API binds localhost only")


def check_metrics(repo: Path, smoke: Smoke) -> None:
    result = run(["python3", str(repo / "control-plane" / "monitoring" / "collect_metrics.py")], repo)
    if result.returncode != 0:
        smoke.fail("metrics collector works")
        return
    metrics = repo / "control-plane" / "dashboard" / "public" / "metrics.json"
    try:
        json.loads(metrics.read_text())
    except Exception:
        smoke.fail("metrics.json valid")
    else:
        smoke.pass_("metrics collector works")
        smoke.pass_("metrics.json valid")


def check_cloudflare_plan(repo: Path, smoke: Smoke) -> None:
    result = run([str(repo / "scripts" / "oreo-cloudflare-plan"), "--json"], repo)
    if result.returncode != 0:
        smoke.fail("Cloudflare plan generated")
        return
    try:
        plan = json.loads(result.stdout)
    except json.JSONDecodeError:
        smoke.fail("Cloudflare plan JSON valid")
        return
    path = repo / "cloudflare" / "planned-ingress.yml"
    smoke.check(path.exists() and "http_status:404" in path.read_text(), "Cloudflare plan generated")
    smoke.check(plan.get("providerEnabled") is False, "Cloudflare disabled by default")


def check_funnel(repo: Path, smoke: Smoke, offline: bool) -> None:
    if offline:
        smoke.warn("Funnel check skipped in offline mode")
        return
    if not shutil.which("tailscale"):
        smoke.warn("tailscale unavailable; Funnel check skipped")
        return
    result = run(["tailscale", "funnel", "status"], repo)
    output = f"{result.stdout}\n{result.stderr}".strip().lower()
    detected = "https://" in output or "funnel on" in output or "enabled" in output
    smoke.check(not detected, "no Funnel detected")


def check_cloudflared(repo: Path, smoke: Smoke, offline: bool) -> None:
    if offline:
        smoke.warn("cloudflared service check skipped in offline mode")
        return
    if not shutil.which("systemctl"):
        smoke.warn("systemctl unavailable; cloudflared check skipped")
        return
    result = run(["systemctl", "is-active", "cloudflared"], repo)
    smoke.check(result.stdout.strip() != "active", "no unexpected cloudflared active")


def check_tracked_secrets(repo: Path, smoke: Smoke) -> None:
    items = tracked_files(repo)
    if not items:
        smoke.fail("tracked secrets check ran")
        return
    bad = []
    for item in items:
        path = Path(item)
        name = path.name.lower()
        suffix = path.suffix.lower()
        if (
            name in {".env", "control-token", "audit.log"}
            or name.startswith(".env.")
            or ".env." in name
            or suffix in {".pem", ".key", ".p12", ".pfx"}
        ):
            bad.append(item)
    smoke.check(not bad, "no tracked secrets")


def check_tracked_runtime_and_source(repo: Path, smoke: Smoke) -> None:
    items = tracked_files(repo)
    if not items:
        smoke.fail("tracked file inventory available")
        return
    manifests = {workload_id: load_manifest(repo, workload_id) for workload_id in workload_map(repo)}
    tracked_source = []
    tracked_runtime = []
    for item in items:
        parts = Path(item).parts
        if len(parts) >= 3 and parts[0] == "workloads" and parts[2] == "source":
            manifest = manifests.get(parts[1], {})
            security = manifest.get("security", {}) if manifest else {}
            if not security.get("trackedByOreoCloudGit", False):
                tracked_source.append(item)
        if parts and parts[0] == "runtime" and Path(item).name != ".gitkeep":
            tracked_runtime.append(item)
    smoke.check(not tracked_source, "no unapproved workload source tracked")
    smoke.check(not tracked_runtime, "no runtime artifacts tracked")


def check_workload_manifests(repo: Path, smoke: Smoke) -> None:
    result = run([str(repo / "scripts" / "validate-manifests")], repo)
    if result.returncode != 0:
        smoke.fail("workload manifests schema-valid")
        for line in result.stdout.splitlines():
            if line.startswith("FAIL "):
                smoke.fail(line[5:])
        return
    workloads = workload_map(repo)
    for workload_id, workload in workloads.items():
        if workload.get("migration", {}).get("status") == "migrated" and not (repo / "workloads" / workload_id / "manifest.json").exists():
            smoke.fail(f"{workload_id} migrated workload has manifest")
            return
    smoke.pass_("workload manifests schema-valid")
    smoke.pass_("workload manifest paths valid")
    smoke.pass_("workload manifest operation policy valid")


def check_migration_and_backup(repo: Path, smoke: Smoke) -> None:
    ok = True
    for workload_id, workload in workload_map(repo).items():
        migration = workload.get("migration", {})
        status = str(migration.get("status", ""))
        if status not in MIGRATION_STATUSES:
            smoke.fail(f"{workload_id} migration status valid")
            ok = False
        manifest = load_manifest(repo, workload_id)
        if status == "migrated":
            backup = manifest.get("backup", {}) if manifest else {}
            backup_status = str(backup.get("status", ""))
            if not manifest or backup_status not in BACKUP_STATUSES or not backup_status:
                smoke.fail(f"{workload_id} migrated workload has backup plan")
                ok = False
    if ok:
        smoke.pass_("migration statuses valid")
        smoke.pass_("backup plans exist for migrated workloads")


def checksum_valid(path: Path) -> bool:
    rows = (path / "checksums.sha256").read_text().splitlines()
    if not rows:
        return False
    for row in rows:
        digest, _, name = row.partition("  ")
        target = path / name
        if not target.exists() or not target.is_file():
            return False
        actual = hashlib.sha256(target.read_bytes()).hexdigest()
        if actual != digest:
            return False
    return True


def check_latest_backup_artifact(repo: Path, smoke: Smoke, offline: bool) -> None:
    ok = True
    checked = False
    for workload_id in workload_map(repo):
        manifest = load_manifest(repo, workload_id)
        backup = manifest.get("backup", {}) if manifest else {}
        operations = manifest.get("operations", {}) if manifest else {}
        if not (backup.get("backupAllowed") or operations.get("backupAllowed")):
            continue
        destination = Path(str(backup.get("destination", "")))
        if not destination.exists():
            if offline:
                smoke.warn(f"{workload_id} latest approved backup artifact unavailable in offline mode")
                continue
            smoke.fail(f"{workload_id} latest approved backup artifact exists")
            ok = False
            continue
        runs = sorted(path for path in destination.iterdir() if path.is_dir())
        if not runs:
            if offline:
                smoke.warn(f"{workload_id} latest approved backup artifact unavailable in offline mode")
                continue
            smoke.fail(f"{workload_id} latest approved backup artifact exists")
            ok = False
            continue
        latest = runs[-1]
        required = ["manifest.json", "files.tar.gz", "checksums.sha256", "restore-plan.md", "backup-summary.json"]
        missing = [name for name in required if not (latest / name).is_file()]
        if missing:
            smoke.fail(f"{workload_id} latest approved backup artifact valid")
            ok = False
            continue
        try:
            json.loads((latest / "manifest.json").read_text())
            summary = json.loads((latest / "backup-summary.json").read_text())
            with tarfile.open(latest / "files.tar.gz", "r:gz") as archive:
                names = archive.getnames()
        except Exception:
            smoke.fail(f"{workload_id} latest approved backup artifact valid")
            ok = False
            continue
        if summary.get("workloadId") != workload_id or not checksum_valid(latest):
            smoke.fail(f"{workload_id} latest approved backup artifact valid")
            ok = False
            continue
        if backup.get("source") and "source/docker-compose.yml" not in names:
            smoke.fail(f"{workload_id} latest approved backup artifact contains source")
            ok = False
            continue
        checked = True
    if ok:
        if checked:
            smoke.pass_("latest approved backup artifact valid")
        elif not offline:
            smoke.fail("latest approved backup artifact valid")


def check_operation_permissions(repo: Path, smoke: Smoke) -> None:
    ok = True
    for name in [*OPERATION_SCRIPTS, "install-operator-links"]:
        path = repo / "scripts" / name
        if not (path.exists() and path.stat().st_mode & 0o111):
            smoke.fail(f"{name} exists and is executable")
            ok = False
    for workload_id in workload_map(repo):
        manifest = load_manifest(repo, workload_id)
        if not manifest:
            continue
        operations = manifest.get("operations", {})
        for key in ["logsAllowed", "restartAllowed", "backupAllowed", "dashboardActionsAllowed", "approvedForCloudflareProtectedDemo", "requiresConfirmation"]:
            if key in operations and not isinstance(operations[key], bool):
                smoke.fail(f"{workload_id} operation permission {key} is boolean")
                ok = False
        runtime = manifest.get("runtime", {})
        if operations.get("logsAllowed") or operations.get("restartAllowed"):
            if runtime.get("type") != "docker-compose" or not runtime.get("composePath") or not runtime.get("composeProject"):
                smoke.fail(f"{workload_id} allowed operations have docker-compose runtime")
                ok = False
    if ok:
        smoke.pass_("operation scripts exist")
        smoke.pass_("operation permissions valid")


def check_operator_links(repo: Path, smoke: Smoke, offline: bool) -> None:
    if offline:
        smoke.warn("operator link check skipped in offline mode")
        return
    ok = True
    scripts_dir = repo / "scripts"
    prefix = Path("/usr/local/bin")
    for link_name, target_name in OPERATOR_LINKS.items():
        link = prefix / link_name
        target = scripts_dir / target_name
        if not link.is_symlink():
            smoke.fail(f"{link_name} operator link exists")
            ok = False
            continue
        actual = link.resolve(strict=False)
        if actual != target:
            smoke.fail(f"{link_name} operator link target valid")
            ok = False
        if scripts_dir not in actual.parents:
            smoke.fail(f"{link_name} operator link stays under scripts")
            ok = False
        if not (target.exists() and target.stat().st_mode & 0o111):
            smoke.fail(f"{link_name} operator link target executable")
            ok = False
    if ok:
        smoke.pass_("operator links exist")
        smoke.pass_("operator link targets executable")
        smoke.pass_("operator links do not point outside scripts")


def check_dashboard_v2(repo: Path, smoke: Smoke) -> None:
    html_path = repo / "control-plane" / "dashboard" / "public" / "index.html"
    if not html_path.exists():
        smoke.fail("dashboard V2 generated")
        return
    html = html_path.read_text()
    required = ["Access Plan", "Backups", "System", "Events", "Workloads", "Cloudflare Plan", 'id="workloads"']
    forbidden = ["control-token", "Authorization: Bearer", "PRIVATE KEY", "BEGIN ", ".env="]
    smoke.check(all(item in html for item in required), "dashboard static shell generated")
    smoke.check(not any(item in html for item in forbidden), "dashboard static shell contains no secret markers")


def check_logs_sanitization(smoke: Smoke) -> None:
    lines, redacted = sanitize_log_text("ok\nTOKEN=abc123\n" + ("x" * 700), max_lines=100)
    joined = "\n".join(lines)
    smoke.check("abc123" not in joined and "[redacted" in joined and redacted, "logs preview capped/sanitized")


def check_policy_effective_access(repo: Path, smoke: Smoke) -> None:
    ok = True
    access = load_json_file(repo / "config" / "access.json")
    routes = load_json_file(repo / "config" / "routes.json")
    workloads = workload_map(repo)
    for workload_id, item in access.get("workloads", {}).items():
        effective = str(item.get("effective", ""))
        privacy = privacy_for(repo, workload_id)
        workload = workloads.get(workload_id, {})
        if effective == "cloudflare-public" and privacy not in {"unclassified", "personal"}:
            smoke.fail(f"{workload_id} effective access policy valid")
            ok = False
        if effective == "cloudflare-protected" and privacy not in SAFE_CLOUDFLARE_PRIVACY:
            smoke.fail(f"{workload_id} protected effective access policy valid")
            ok = False
        if effective.startswith("cloudflare"):
            route = routes.get("workloadRoutes", {}).get(workload_id, {}).get("cloudflare", {})
            if not route.get("enabled"):
                smoke.fail(f"{workload_id} Cloudflare effective access has enabled route")
                ok = False
        if workload.get("kind") == "admin-tool" and effective.startswith("cloudflare"):
            smoke.fail(f"{workload_id} admin tool is not Cloudflare exposed")
            ok = False
    if ok:
        smoke.pass_("effective access policy valid")


def check_cloudflare_policy(repo: Path, smoke: Smoke) -> None:
    result = run([str(repo / "scripts" / "oreo-cloudflare-plan"), "--json"], repo)
    if result.returncode != 0:
        smoke.fail("Cloudflare policy plan generated")
        return
    try:
        plan = json.loads(result.stdout)
    except json.JSONDecodeError:
        smoke.fail("Cloudflare policy plan JSON valid")
        return
    workloads = workload_map(repo)
    ok = True
    planned_ids = {str(item.get("workloadId")) for item in plan.get("requested", [])}
    ingress_hosts = {str(item.get("hostname")) for item in plan.get("ingress", [])}
    routes = load_json_file(repo / "config" / "routes.json")
    host_to_workload = {
        str(route.get("cloudflare", {}).get("hostname")): workload_id
        for workload_id, route in routes.get("workloadRoutes", {}).items()
        if route.get("cloudflare", {}).get("hostname")
    }
    for workload_id in planned_ids:
        workload = workloads.get(workload_id, {})
        privacy = privacy_for(repo, workload_id)
        if workload.get("kind") == "admin-tool" or privacy not in SAFE_CLOUDFLARE_PRIVACY:
            smoke.fail(f"{workload_id} Cloudflare planned workload allowed")
            ok = False
    for host in ingress_hosts:
        workload_id = host_to_workload.get(host)
        if not workload_id:
            smoke.fail(f"{host} planned ingress maps to known workload")
            ok = False
            continue
        workload = workloads.get(workload_id, {})
        haystack = json.dumps(workload, sort_keys=True).lower()
        privacy = privacy_for(repo, workload_id)
        blocked_target = workload.get("kind") == "admin-tool" or privacy not in SAFE_CLOUDFLARE_PRIVACY or any(
            marker in haystack for marker in ["postgres", "docker.sock", "docker-socket", "/.ssh", "control-api"]
        )
        if blocked_target:
            smoke.fail(f"{workload_id} blocked workload absent from Cloudflare ingress")
            ok = False
    if ok:
        smoke.pass_("Cloudflare plan excludes blocked workloads")


def check_cloudflare_activation_guard(repo: Path, smoke: Smoke) -> None:
    preview = run([str(repo / "scripts" / "oreo-cloudflare-activate-preview"), "--json"], repo)
    try:
        payload = json.loads(preview.stdout)
    except json.JSONDecodeError:
        smoke.fail("Cloudflare activation preview JSON valid")
        return
    blockers = payload.get("blockers", [])
    invalid_blocker = any(".invalid" in str(item) for item in blockers)
    smoke.check(preview.returncode == 2 and invalid_blocker, "Cloudflare activation blocks placeholder hostname")
    smoke.check(payload.get("allowQuickTunnels") is False, "Cloudflare activation refuses quick tunnel mode")
    rollback = run([str(repo / "scripts" / "oreo-cloudflare-rollback")], repo)
    smoke.check(rollback.returncode == 0, "Cloudflare rollback preview works")


def check_access_reconcile(repo: Path, smoke: Smoke) -> None:
    result = run([str(repo / "scripts" / "oreo-access-reconcile"), "--offline", "--json"], repo)
    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError:
        smoke.fail("effective access reconcile JSON valid")
        return
    smoke.check(result.returncode == 0 and payload.get("ok") is True, "effective access reconcile clean")


def check_p3_evidence(repo: Path, smoke: Smoke) -> None:
    required_docs = [
        "P3_BASELINE.md",
        "P3_HELLO_NGINX_RESTORE_DRILL.md",
        "P3_TAILNET_ROUTING_REVIEW.md",
        "P3_CLOUDFLARE_PREREQS.md",
        "P3_CLOUDFLARE_ACTIVATION.md",
        "P3_CLOUDFLARE_ROLLBACK.md",
        "P3_NEXT_WORKLOAD_DISCOVERY.md",
    ]
    missing = [name for name in required_docs if not (repo / "docs" / name).is_file()]
    smoke.check(not missing, "P3 evidence docs exist")

    restore_doc = repo / "docs" / "P3_HELLO_NGINX_RESTORE_DRILL.md"
    if restore_doc.exists():
        content = restore_doc.read_text()
        smoke.check(
            "CHECKSUMS_OK true" in content and "source/docker-compose.yml present" in content,
            "P3 restore drill evidence recorded",
        )

    activation_doc = repo / "docs" / "P3_CLOUDFLARE_ACTIVATION.md"
    access = load_json_file(repo / "config" / "access.json")
    exposure = load_json_file(repo / "config" / "exposure.json")
    hello = access.get("workloads", {}).get("hello-nginx", {})
    cloudflare = exposure.get("providers", {}).get("cloudflare", {})
    deferred = (
        hello.get("effective") == "local"
        and str(hello.get("urls", {}).get("cloudflare", "")).endswith(".invalid")
        and cloudflare.get("enabled") is False
        and cloudflare.get("provisioned") is False
    )
    smoke.check(deferred, "P3 Cloudflare activation remains deferred")
    if activation_doc.exists():
        content = activation_doc.read_text()
        smoke.check("Decision: `defer`" in content and "effective access remains `local`" in content, "P3 deferral evidence recorded")


def check_p4_evidence(repo: Path, smoke: Smoke) -> None:
    required_docs = [
        "P4_BASELINE.md",
        "P4_WORKLOAD_RISK_MATRIX.md",
        "P4_BACKUP_STRATEGY.md",
        "P4_REVIEW_UI_MIGRATION.md",
        "P4_RESTORE_DRILLS.md",
        "P4_INTERNAL_ROUTING.md",
        "P4_CLOSEOUT.md",
    ]
    missing = [name for name in required_docs if not (repo / "docs" / name).is_file()]
    smoke.check(not missing, "P4 evidence docs exist")

    blocked_backup = ["review-ui", "dozzle", "uptime-kuma", "hastur", "intake-os"]
    bad_backup_state = []
    for workload_id in blocked_backup:
        manifest = load_manifest(repo, workload_id)
        backup = manifest.get("backup", {}) if manifest else {}
        operations = manifest.get("operations", {}) if manifest else {}
        if (
            backup.get("backupAllowed") is not False
            or backup.get("restoreAllowed") is not False
            or operations.get("backupAllowed") is not False
        ):
            bad_backup_state.append(workload_id)
    smoke.check(not bad_backup_state, "P4 stateful backup execution remains disabled")

    review_manifest = load_manifest(repo, "review-ui")
    smoke.check(
        review_manifest.get("migration", {}).get("status") == "skipped",
        "P4 review-ui migration explicitly deferred",
    )


def check_doctor(repo: Path, smoke: Smoke) -> None:
    result = run([str(repo / "scripts" / "oreo-doctor"), "--json"], repo)
    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError:
        smoke.fail("doctor JSON valid")
        return
    smoke.check(result.returncode == 0 and payload.get("ok") is True, "doctor security audit clean")


def check_cli(repo: Path, smoke: Smoke, offline: bool) -> None:
    workloads = run([str(repo / "scripts" / "oreo-workloads")], repo)
    smoke.check(workloads.returncode == 0, "workload CLI works")
    health = run([str(repo / "scripts" / "oreo-health")], repo)
    if health.returncode == 0:
        smoke.pass_("health CLI works")
    elif offline:
        smoke.warn("health CLI failed in offline mode")
    else:
        smoke.fail("health CLI works")


def check_caddy(repo: Path, smoke: Smoke, offline: bool) -> None:
    plan = run([str(repo / "scripts" / "oreo-caddy-dashboard-plan"), "--json"], repo)
    smoke.check(plan.returncode == 0, "Caddy dashboard route generated")
    planned = repo / "caddy" / "dashboard.Caddyfile"
    if planned.exists():
        content = planned.read_text()
        smoke.check("bind 0.0.0.0" not in content and "reverse_proxy 127.0.0.1:8099" in content, "Caddy route is private")
    if not shutil.which("caddy"):
        smoke.warn("caddy unavailable; validation skipped")
        return
    planned_validate = run(["caddy", "validate", "--config", str(planned), "--adapter", "caddyfile"], repo)
    smoke.check(planned_validate.returncode == 0, "planned Caddy route validates")
    if not offline:
        live = Path("/etc/caddy/Caddyfile")
        if live.exists():
            live_validate = run(["caddy", "validate", "--config", str(live)], repo)
            smoke.check(live_validate.returncode == 0, "live Caddy validates")
        else:
            smoke.fail("live Caddyfile exists")


def main() -> int:
    parser = argparse.ArgumentParser(description="Run Oreo Cloud P0 smoke checks.")
    parser.add_argument("--root", type=Path, default=Path(__file__).resolve().parents[1])
    parser.add_argument("--offline", action="store_true", help="Skip live listener/service checks.")
    args = parser.parse_args()
    repo = args.root.expanduser().resolve()
    smoke = Smoke()

    check_git(repo, smoke)
    check_json(repo, smoke)
    check_dashboard(repo, smoke)
    check_dashboard_runtime_cleanliness(repo, smoke)
    check_workload_manifests(repo, smoke)
    check_tracked_runtime_and_source(repo, smoke)
    check_migration_and_backup(repo, smoke)
    check_latest_backup_artifact(repo, smoke, args.offline)
    check_operation_permissions(repo, smoke)
    check_operator_links(repo, smoke, args.offline)
    check_dashboard_v2(repo, smoke)
    check_policy_effective_access(repo, smoke)
    check_api_bind(repo, smoke, args.offline)
    check_action_api_boundaries(repo, smoke)
    check_logs_sanitization(smoke)
    check_metrics(repo, smoke)
    check_cloudflare_plan(repo, smoke)
    check_cloudflare_policy(repo, smoke)
    check_cloudflare_activation_guard(repo, smoke)
    check_access_reconcile(repo, smoke)
    check_p3_evidence(repo, smoke)
    check_p4_evidence(repo, smoke)
    check_funnel(repo, smoke, args.offline)
    check_cloudflared(repo, smoke, args.offline)
    check_tracked_secrets(repo, smoke)
    check_doctor(repo, smoke)
    check_cli(repo, smoke, args.offline)
    check_caddy(repo, smoke, args.offline)

    print("")
    print(f"Smoke summary: {len(smoke.failures)} failure(s), {len(smoke.warnings)} warning(s)")
    if smoke.failures:
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
