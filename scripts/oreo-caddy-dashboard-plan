#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from pathlib import Path
from typing import Any

from oreo_common import fail, load_json, root


def render(routes: dict[str, Any]) -> str:
    dashboard = routes["dashboard"]
    api = routes["api"]
    tailscale_ip = routes.get("observed", {}).get("tailscaleIp", "")
    port = int(dashboard["port"])
    if dashboard.get("bind") != "tailscale":
        fail("dashboard route must bind to tailscale in P0")
    if not tailscale_ip:
        fail("missing observed Tailscale IP in config/routes.json")
    if tailscale_ip == "0.0.0.0":
        fail("refusing to generate a public dashboard bind")
    if api.get("bind") != "127.0.0.1" or bool(api.get("public")):
        fail("control API must remain private at 127.0.0.1")
    return f"""# Generated private Oreo Cloud dashboard route.
# Review, back up /etc/caddy/Caddyfile, validate, then reload manually.
http://oreochiserver:{port}, http://{tailscale_ip}:{port} {{
    bind {tailscale_ip}
    root * /srv/oreo-cloud/control-plane/dashboard/public
    handle /api/* {{
        reverse_proxy {api["bind"]}:{api["port"]}
    }}
    file_server
}}
"""


def main() -> int:
    parser = argparse.ArgumentParser(description="Generate the private Oreo Cloud dashboard Caddy route.")
    parser.add_argument("--json", action="store_true", help="Print route metadata as JSON.")
    args = parser.parse_args()
    routes = load_json("routes.json")
    content = render(routes)
    output = root() / "caddy" / "dashboard.Caddyfile"
    output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text(content)
    payload = {
        "ok": True,
        "generated": str(output),
        "bind": routes["observed"]["tailscaleIp"],
        "port": routes["dashboard"]["port"],
        "apiProxy": f'{routes["api"]["bind"]}:{routes["api"]["port"]}',
        "manualInstallRequired": True,
    }
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print("Private Caddy Dashboard Route")
        print("")
        print(f"Generated: {output}")
        print(f"Bind: {payload['bind']}:{payload['port']}")
        print(f"API proxy: {payload['apiProxy']}")
        print("")
        print("Manual install after review:")
        print('sudo cp /etc/caddy/Caddyfile "/etc/caddy/Caddyfile.backup.$(date +%Y%m%d-%H%M%S)"')
        print("sudo caddy validate --config /etc/caddy/Caddyfile")
        print("sudo systemctl reload caddy")
        print("")
        print("No Caddyfile was installed, no service was reloaded, and no public route was exposed.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
