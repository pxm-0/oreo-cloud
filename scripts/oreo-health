#!/usr/bin/env python3
from __future__ import annotations

from oreo_common import http_status, print_table, workloads


def main() -> int:
    rows = []
    failed = False
    for workload in workloads():
        health = workload.get("health", {})
        url = health.get("url", "")
        expected = str(health.get("expectedStatus", ""))
        status, detail = http_status(url, float(health.get("timeoutSeconds", 3)))
        ok = status == expected if expected else status not in {"fail", "skip"}
        failed = failed or not ok
        rows.append([workload["id"], url or "-", expected or "-", status, "ok" if ok else detail])
    print_table(["id", "url", "expected", "actual", "result"], rows)
    return 1 if failed else 0


if __name__ == "__main__":
    raise SystemExit(main())
