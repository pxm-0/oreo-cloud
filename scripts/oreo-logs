#!/usr/bin/env python3
from __future__ import annotations

import argparse
import subprocess

from oreo_common import audit, fail, operation_allowed, runtime_config


def main() -> int:
    parser = argparse.ArgumentParser(description="Show safe workload logs by workload ID.")
    parser.add_argument("workload_id")
    parser.add_argument("--tail", type=int, default=100)
    parser.add_argument("--follow", action="store_true")
    args = parser.parse_args()

    if args.tail < 1:
        fail("--tail must be at least 1")
    runtime = runtime_config(args.workload_id)
    if not operation_allowed(args.workload_id, "logsAllowed"):
        audit("logs.view", args.workload_id, "blocked", reason="logs not allowed")
        fail(f"logs are not allowed for {args.workload_id}")
    if runtime.get("type") != "docker-compose":
        audit("logs.view", args.workload_id, "blocked", reason="unsupported runtime")
        fail(f"logs require docker-compose runtime for {args.workload_id}")
    compose_path = str(runtime.get("composePath", ""))
    project = str(runtime.get("composeProject", ""))
    service = str(runtime.get("service", ""))
    if not compose_path or not project:
        audit("logs.view", args.workload_id, "blocked", reason="missing compose config")
        fail(f"missing composePath or composeProject for {args.workload_id}")

    command = ["docker", "compose", "-f", compose_path, "-p", project, "logs", "--tail", str(args.tail)]
    if args.follow:
        command.append("--follow")
    if service:
        command.append(service)
    audit("logs.view", args.workload_id, "ok", tail=args.tail, follow=args.follow)
    return subprocess.run(command, check=False).returncode


if __name__ == "__main__":
    raise SystemExit(main())
