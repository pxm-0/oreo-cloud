#!/usr/bin/env python3
from __future__ import annotations

import argparse

from oreo_common import fail, load_manifest, print_table


def main() -> int:
    parser = argparse.ArgumentParser(description="Print the restore plan for a workload.")
    parser.add_argument("workload_id")
    args = parser.parse_args()
    manifest = load_manifest(args.workload_id)
    if not manifest:
        fail(f"missing manifest for {args.workload_id}")
    backup = manifest.get("backup", {})
    database = backup.get("database", {})
    migration = manifest.get("migration", {})
    rows = [
        ["workload", args.workload_id],
        ["backup status", str(backup.get("status", ""))],
        ["destination", str(backup.get("destination", ""))],
        ["restore tested", str(bool(backup.get("restoreTested", False))).lower()],
        ["last restore test", str(backup.get("lastRestoreTestAt", "")) or "-"],
        ["database", str(database.get("type", "none"))],
        ["restore command", str(database.get("restoreCommand", "")) or "-"],
        ["migration rollback", str(migration.get("rollback", "")) or "-"],
    ]
    print_table(["field", "value"], rows)
    print("Restore automation is not enabled in P1; review this plan before any manual restore.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
